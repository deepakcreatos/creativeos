generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model UserRole {
  id        String   @id @default(uuid())
  userId    String   @unique // This matches the Supabase auth.users ID
  role      String   @default("Client") // Founder, Admin, Manager, Creator, Client
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("user_roles")
}
