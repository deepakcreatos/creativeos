generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model ClientDNA {
  id             String   @id @default(uuid())
  userId         String?  @map("user_id")
  clientName     String   @map("client_name")
  industry       String
  targetAudience Json     @default("{}") @map("target_audience")
  brandTone      String   @map("brand_tone")
  geography      Json     @default("{}")
  psychographics Json     @default("{}")
  products       Json?
  competitors    Json?
  version        Int      @default(1)
  semanticTags   String[] @default([]) @map("semantic_tags")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  campaigns      Campaign[]

  @@map("client_dna")
}

model Campaign {
  id             String   @id @default(uuid())
  userId         String?  @map("user_id")
  clientDnaId    String?  @map("client_dna_id")
  name           String   @default("Untitled Campaign")
  objective      String   @default("awareness")
  platforms      Json     @default("[]")
  contentPillars Json     @default("[]") @map("content_pillars")
  dateRange      Json     @default("{}") @map("date_range")
  status         String   @default("draft")
  kpis           Json?
  budget         Json?
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  clientDna      ClientDNA? @relation(fields: [clientDnaId], references: [id])
  strategies     Strategy[]

  @@map("campaigns")
}

model Strategy {
  id         String   @id @default(uuid())
  userId     String?  @map("user_id")
  campaignId String?  @map("campaign_id")
  objective  String   @default("Brand Awareness")
  platforms  Json     @default("[]")
  budget     Json?
  pillars    Json     @default("[]")
  kpis       Json     @default("[]")
  timeline   String   @default("30 days")
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  campaign   Campaign? @relation(fields: [campaignId], references: [id])
  contentItems ContentItem[]

  @@map("strategies")
}

model ContentItem {
  id         String   @id @default(uuid())
  userId     String?  @map("user_id")
  strategyId String?  @map("strategy_id")
  platform   String   @default("LinkedIn")
  copyText   String   @map("copy_text") @db.Text
  mediaUrl   String?  @map("media_url")
  status     String   @default("draft")
  score      Int      @default(0)
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  strategy   Strategy? @relation(fields: [strategyId], references: [id])
  scheduledPosts ScheduledPost[]

  @@map("content_items")
}

model ScheduledPost {
  id           String   @id @default(uuid())
  userId       String?  @map("user_id")
  contentId    String?  @map("content_id")
  platform     String
  scheduledFor DateTime @map("scheduled_for")
  status       String   @default("queued")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  content      ContentItem? @relation(fields: [contentId], references: [id])

  @@map("scheduled_posts")
}
